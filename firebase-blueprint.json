{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user roles and basic information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee", "client"] },
        "bookingCount": { "type": "integer", "description": "Total number of completed bookings" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postcode": { "type": "string" },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "CheckIn": {
      "title": "Employee Check-In",
      "description": "Logs employee attendance and location.",
      "type": "object",
      "properties": {
        "employeeUid": { "type": "string" },
        "employeeName": { "type": "string" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      },
      "required": ["employeeUid", "type", "timestamp"]
    },
    "Booking": {
      "title": "Service Booking",
      "description": "Stores customer service requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "package": { "type": "string" },
        "addons": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "timeWindow": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/checkins/{checkinId}": {
      "schema": "CheckIn",
      "description": "Employee check-in logs."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service booking records."
    }
  }
}
