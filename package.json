{
  "name": "crystalline-max",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:emulators": "PATH=\"/usr/local/opt/openjdk/bin:$PATH\" firebase emulators:start --only auth,firestore,functions,storage",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:functions": "npm --prefix functions run build",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "test:rules": "vitest run tests/firestore.rules.test.ts",
    "test:emulator": "PATH=\"/usr/local/opt/openjdk/bin:$PATH\" firebase emulators:exec --only auth,firestore \"npm run test:rules\"",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run test && npm run test:emulator && npm run build",
    "verify:full": "npm run verify && npm run test:e2e"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
