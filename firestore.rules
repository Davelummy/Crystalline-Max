rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function actorDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function actorRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? actorDoc().data.role
        : null;
    }

    function isAdmin() {
      return actorRole() == 'admin';
    }

    function isEmployee() {
      return actorRole() == 'employee' || actorRole() == 'admin';
    }

    function isCompanyEmail() {
      return isAuthenticated() &&
             request.auth.token.email is string &&
             request.auth.token.email.matches('.*@ctmds\\.co\\.uk$');
    }

    function isAuthEmail(email) {
      return isAuthenticated() &&
             request.auth.token.email is string &&
             request.auth.token.email == email;
    }

    function inviteDoc(employeeId) {
      return get(/databases/$(database)/documents/employeeInvites/$(employeeId));
    }

    function hasValidEmployeeInvite(employeeId, email) {
      return exists(/databases/$(database)/documents/employeeInvites/$(employeeId)) &&
             inviteDoc(employeeId).data.employeeId == employeeId &&
             inviteDoc(employeeId).data.claimed == false &&
             (
               inviteDoc(employeeId).data.email == '' ||
               inviteDoc(employeeId).data.email == email
             );
    }

    function isValidUser(data, userId) {
      let requiredFields = ['uid', 'email', 'role', 'createdAt'];
      let allowedFields = [
        'uid',
        'email',
        'role',
        'displayName',
        'employeeId',
        'bookingCount',
        'fcmToken',
        'phoneNumber',
        'address',
        'city',
        'postcode',
        'position',
        'experience',
        'onboarded',
        'createdAt',
        'updatedAt'
      ];

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid == userId &&
             data.email is string &&
             data.role in ['admin', 'employee', 'client'] &&
             (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
             (!('employeeId' in data) || data.employeeId is string) &&
             (!('fcmToken' in data) || data.fcmToken == null || data.fcmToken is string) &&
             (!('phoneNumber' in data) || data.phoneNumber is string) &&
             (!('address' in data) || data.address is string) &&
             (!('city' in data) || data.city is string) &&
             (!('postcode' in data) || data.postcode is string) &&
             (!('position' in data) || data.position is string) &&
             (!('experience' in data) || data.experience is string) &&
             (!('onboarded' in data) || data.onboarded is bool) &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt is string) &&
             (!('bookingCount' in data) || data.bookingCount is int);
    }

    function isValidInvite(data, employeeId) {
      let requiredFields = ['employeeId', 'displayName', 'email', 'position', 'claimed', 'createdAt'];
      let allowedFields = requiredFields.concat([
        'claimedAt',
        'claimedByUid',
        'claimedByEmail',
        'updatedAt'
      ]);

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.employeeId == employeeId &&
             data.displayName is string &&
             data.email is string &&
             data.position is string &&
             data.claimed is bool &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('claimedAt' in data) || data.claimedAt is timestamp || data.claimedAt is string) &&
             (!('claimedByUid' in data) || data.claimedByUid is string) &&
             (!('claimedByEmail' in data) || data.claimedByEmail is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt is string);
    }

    function isClaimingInvite(employeeId) {
      return isCompanyEmail() &&
             resource.data.employeeId == employeeId &&
             resource.data.claimed == false &&
             request.resource.data.employeeId == resource.data.employeeId &&
             request.resource.data.displayName == resource.data.displayName &&
             request.resource.data.email == resource.data.email &&
             request.resource.data.position == resource.data.position &&
             request.resource.data.createdAt == resource.data.createdAt &&
             request.resource.data.claimed == true &&
             request.resource.data.claimedByUid == request.auth.uid &&
             request.resource.data.claimedByEmail == request.auth.token.email &&
             (resource.data.email == '' || resource.data.email == request.auth.token.email) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'claimed',
               'claimedAt',
               'claimedByUid',
               'claimedByEmail',
               'updatedAt'
             ]) &&
             isValidInvite(request.resource.data, employeeId);
    }

    function isValidBooking(data) {
      let requiredFields = [
        'userId',
        'customerName',
        'customerEmail',
        'serviceId',
        'serviceLabel',
        'addons',
        'address',
        'city',
        'postcode',
        'date',
        'time',
        'timeWindow',
        'total',
        'status',
        'paymentStatus',
        'createdAt'
      ];
      let allowedFields = requiredFields.concat([
        'locationLabel',
        'locationLat',
        'locationLng',
        'locationVerified',
        'assignedStaffId',
        'assignedStaffName',
        'assignedStaffIds',
        'assignedStaffNames',
        'assignedAt',
        'staffAcknowledgedAt',
        'staffAcknowledgedByIds',
        'completedTaskIds',
        'taskProgressPercent',
        'startedAt',
        'completedAt',
        'lastProgressAt',
        'beforePhotoUrl',
        'beforePhotoPath',
        'afterPhotoUrl',
        'afterPhotoPath',
        'beforePhotos',
        'afterPhotos',
        'paymentSessionId',
        'paymentAmount',
        'paidAt',
        'adminNote',
        'cancelledAt',
        'cancelledBy',
        'updatedAt'
      ]);

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.userId is string &&
             data.customerEmail is string &&
             data.customerName is string &&
             data.serviceId is string &&
             data.serviceLabel is string &&
             data.addons is list &&
             data.address is string &&
             data.city is string &&
             data.postcode is string &&
             (!('locationLabel' in data) || data.locationLabel is string) &&
             (!('locationLat' in data) || data.locationLat is number) &&
             (!('locationLng' in data) || data.locationLng is number) &&
             (!('locationVerified' in data) || data.locationVerified is bool) &&
             data.date is string &&
             data.time is string &&
             data.timeWindow is string &&
             data.total is number &&
             data.status in ['pending', 'confirmed', 'in_progress', 'completed', 'cancelled'] &&
             data.paymentStatus in ['pending', 'paid', 'not_required'] &&
             (!('paymentSessionId' in data) || data.paymentSessionId == null || data.paymentSessionId is string) &&
             (!('paymentAmount' in data) || data.paymentAmount == null || data.paymentAmount is number) &&
             (!('paidAt' in data) || data.paidAt == null || data.paidAt is timestamp || data.paidAt is string) &&
             (!('adminNote' in data) || data.adminNote == null || data.adminNote is string) &&
             (!('cancelledAt' in data) || data.cancelledAt == null || data.cancelledAt is timestamp || data.cancelledAt is string) &&
             (!('cancelledBy' in data) || data.cancelledBy == null || data.cancelledBy in ['customer', 'admin']) &&
             (!('completedTaskIds' in data) || data.completedTaskIds is list) &&
             (!('taskProgressPercent' in data) || data.taskProgressPercent is number) &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('assignedStaffId' in data) || data.assignedStaffId == null || data.assignedStaffId is string) &&
             (!('assignedStaffName' in data) || data.assignedStaffName == null || data.assignedStaffName is string) &&
             (!('assignedStaffIds' in data) || data.assignedStaffIds is list) &&
             (!('assignedStaffNames' in data) || data.assignedStaffNames is list) &&
             (!('assignedAt' in data) || data.assignedAt == null || data.assignedAt is timestamp || data.assignedAt is string) &&
             (!('staffAcknowledgedAt' in data) || data.staffAcknowledgedAt == null || data.staffAcknowledgedAt is timestamp || data.staffAcknowledgedAt is string) &&
             (!('staffAcknowledgedByIds' in data) || data.staffAcknowledgedByIds is list) &&
             (!('startedAt' in data) || data.startedAt == null || data.startedAt is timestamp || data.startedAt is string) &&
             (!('completedAt' in data) || data.completedAt == null || data.completedAt is timestamp || data.completedAt is string) &&
             (!('lastProgressAt' in data) || data.lastProgressAt == null || data.lastProgressAt is timestamp || data.lastProgressAt is string) &&
             (!('beforePhotoUrl' in data) || data.beforePhotoUrl == null || data.beforePhotoUrl is string) &&
             (!('beforePhotoPath' in data) || data.beforePhotoPath == null || data.beforePhotoPath is string) &&
             (!('afterPhotoUrl' in data) || data.afterPhotoUrl == null || data.afterPhotoUrl is string) &&
             (!('afterPhotoPath' in data) || data.afterPhotoPath == null || data.afterPhotoPath is string) &&
             (!('beforePhotos' in data) || data.beforePhotos is list) &&
             (!('afterPhotos' in data) || data.afterPhotos is list) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt is string);
    }

    function isValidCheckIn(data) {
      return data.keys().hasAll(['employeeUid', 'type', 'timestamp']) &&
             data.keys().hasOnly([
               'employeeUid',
               'employeeName',
               'type',
               'timestamp',
               'location',
               'bookingId',
               'bookingAddress',
               'distanceMeters',
               'serverValidated'
             ]) &&
             data.employeeUid == request.auth.uid &&
             data.type in ['in', 'out'] &&
             data.timestamp is timestamp &&
             (!('employeeName' in data) || data.employeeName is string) &&
             (!('bookingId' in data) || data.bookingId == null || data.bookingId is string) &&
             (!('bookingAddress' in data) || data.bookingAddress == null || data.bookingAddress is string) &&
             (!('distanceMeters' in data) || data.distanceMeters == null || data.distanceMeters is number) &&
             (!('serverValidated' in data) || data.serverValidated is bool) &&
             (!('location' in data) || (
               data.location is map &&
               data.location.keys().hasOnly(['latitude', 'longitude']) &&
               data.location.latitude is number &&
               data.location.longitude is number
             ));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
                    isValidUser(request.resource.data, userId) &&
                    isAuthEmail(request.resource.data.email) &&
                    (
                      request.resource.data.role == 'client' ||
                      (
                        request.resource.data.role == 'employee' &&
                        isCompanyEmail() &&
                        'employeeId' in request.resource.data &&
                        hasValidEmployeeInvite(request.resource.data.employeeId, request.resource.data.email)
                      )
                    );
      allow update: if (
        isOwner(userId) &&
        isValidUser(request.resource.data, userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['bookingCount']) &&
        (
          resource.data.role != 'employee' ||
          request.resource.data.employeeId == resource.data.employeeId
        )
      ) || (
        isAdmin() &&
        isValidUser(request.resource.data, userId) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email
      );
    }

    match /employeeInvites/{employeeId} {
      allow get: if isAdmin() || isCompanyEmail();
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidInvite(request.resource.data, employeeId);
      allow update: if (
        isAdmin() &&
        isValidInvite(request.resource.data, employeeId)
      ) || isClaimingInvite(employeeId);
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isEmployee());
      allow create: if isAuthenticated() &&
                    isValidBooking(request.resource.data) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.customerEmail == request.auth.token.email &&
                    ('locationVerified' in request.resource.data) &&
                    request.resource.data.locationVerified == true;
      allow update: if (
        isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.cancelledBy == 'customer' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt', 'cancelledBy'])
      ) || (
        isAdmin() &&
        isValidBooking(request.resource.data)
      ) || (
        isEmployee() &&
        (
          resource.data.assignedStaffId == request.auth.uid ||
          (
            'assignedStaffIds' in resource.data &&
            resource.data.assignedStaffIds is list &&
            request.auth.uid in resource.data.assignedStaffIds
          )
        ) &&
        isValidBooking(request.resource.data)
      );
    }

    match /checkins/{checkinId} {
      allow get: if isAdmin() || (isAuthenticated() && resource.data.employeeUid == request.auth.uid);
      allow list: if isAdmin() || isEmployee();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'general' || isAuthenticated();
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
